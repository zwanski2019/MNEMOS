# ─── CockroachDB Cloud ───────────────────────────────────────────────
# Full SQL connection string to the CRDB Cloud cluster (do NOT commit real creds)
DATABASE_URL=postgresql://user:pass@host:26257/mnemos?sslmode=verify-full
CRDB_CLUSTER_ID=
# Cloud Managed MCP endpoint (analyst reads memory read-only through this)
CRDB_MCP_URL=https://cockroachlabs.cloud/mcp
CRDB_MCP_API_KEY=

# ─── AWS ─────────────────────────────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Bedrock model ids
BEDROCK_ANALYST_MODEL=us.anthropic.claude-sonnet-4-5-v1:0
BEDROCK_EMBED_MODEL=amazon.titan-embed-text-v2:0
# S3 bucket for raw artifacts
S3_ARTIFACT_BUCKET=mnemos-artifacts

# ─── NATS ────────────────────────────────────────────────────────────
NATS_URL=nats://localhost:4222

# ─── Gateway / Web ───────────────────────────────────────────────────
GATEWAY_URL=http://localhost:8080
NEXT_PUBLIC_GATEWAY_URL=http://localhost:8080
# Per-run cost ceiling (USD); agent halts when exceeded
MNEMOS_COST_CEILING_USD=5.00
